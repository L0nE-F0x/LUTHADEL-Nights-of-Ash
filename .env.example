# Client → which relay server to connect to in a HOSTED (Netlify) build.
# Leave UNSET for single-player (the default, and what the live site does today).
# Local `npm run dev` ignores this and auto-connects to ws://localhost:8090.
#
# After deploying the server (Render or Fly), set this to its wss:// URL, e.g.:
#   VITE_SERVER_URL=wss://luthadel-relay.onrender.com
#   VITE_SERVER_URL=wss://luthadel-relay.fly.dev
#
# Vite bakes env vars at BUILD time, so on Netlify set it under
# Site settings → Environment variables, then trigger a redeploy.
# (Copy this file to `.env` for local overrides — keep `.env` out of git.)
VITE_SERVER_URL=
